                 htmlUrl="https://www.anthropic.com/news"/>
        <outline type="rss" text="Anthropic Research (社区源)" title="Anthropic Research (社区源)"
                 xmlUrl="https://raw.githubusercontent.com/Olshansk/rss-feeds/main/feeds/feed_anthropic_research.xml"
                 htmlUrl="https://www.anthropic.com/research"/>
        <outline type="rss" text="Anthropic Engineering (社区源)" title="Anthropic Engineering (社区源)"
                 xmlUrl="https://raw.githubusercontent.com/Olshansk/rss-feeds/main/feeds/feed_anthropic_engineering.xml"
                 htmlUrl="https://www.anthropic.com/engineering"/>
        <outline type="rss" text="OpenAI News" title="OpenAI News"
                 xmlUrl="https://openai.com/news/rss.xml"
                 htmlUrl="https://openai.com/news"/>
        <outline type="rss" text="Google DeepMind Blog" title="Google DeepMind Blog"
