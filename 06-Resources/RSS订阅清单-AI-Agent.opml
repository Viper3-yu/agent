<?xml version="1.0" encoding="UTF-8"?>
<opml version="2.0">
  <head>
    <title>AI / Agent 知识库 RSS 订阅清单</title>
    <dateCreated>Mon, 15 Jun 2026 00:00:00 +0800</dateCreated>
    <ownerName>obsidian1 vault</ownerName>
  </head>
  <body>
    <!-- ============================================================ -->
    <!-- Tier 1：核心源，日常必看（每天扫一遍）                            -->
    <!-- ============================================================ -->
    <outline text="🥇 Tier 1 - 核心源（日常必看）" title="🥇 Tier 1 - 核心源（日常必看）">
      <!-- 论文 -->
      <outline text="📚 论文" title="📚 论文">
        <outline type="rss" text="arXiv - cs.AI (人工智能)" title="arXiv - cs.AI (人工智能)"
                 xmlUrl="http://export.arxiv.org/rss/cs.AI"
                 htmlUrl="https://arxiv.org/list/cs.AI/recent"/>
        <outline type="rss" text="arXiv - cs.CL (NLP/LLM)" title="arXiv - cs.CL (NLP/LLM)"
                 xmlUrl="http://export.arxiv.org/rss/cs.CL"
                 htmlUrl="https://arxiv.org/list/cs.CL/recent"/>
        <outline type="rss" text="arXiv - cs.MA (多智能体)" title="arXiv - cs.MA (多智能体)"
                 xmlUrl="http://export.arxiv.org/rss/cs.MA"
                 htmlUrl="https://arxiv.org/list/cs.MA/recent"/>
        <outline type="rss" text="arXiv - cs.LG (机器学习)" title="arXiv - cs.LG (机器学习)"
                 xmlUrl="http://export.arxiv.org/rss/cs.LG"
                 htmlUrl="https://arxiv.org/list/cs.LG/recent"/>
        <outline type="rss" text="Hugging Face Daily Papers (社区源)" title="Hugging Face Daily Papers (社区源)"
                 xmlUrl="https://papers.takara.ai/api/feed"
                 htmlUrl="https://huggingface.co/papers"/>
      </outline>

      <!-- 官方实验室 -->
      <outline text="🏭 官方实验室博客" title="🏭 官方实验室博客">
        <outline type="rss" text="Anthropic News (社区源)" title="Anthropic News (社区源)"
