      <!-- 个人博主 -->
      <outline text="✍️ 个人博主（最高价值）" title="✍️ 个人博主（最高价值）">
        <outline type="rss" text="Simon Willison's Weblog" title="Simon Willison's Weblog"
                 xmlUrl="https://simonwillison.net/atom/everything/"
                 htmlUrl="https://simonwillison.net/"/>
        <outline type="rss" text="Lilian Weng - Lil'Log" title="Lilian Weng - Lil'Log"
                 xmlUrl="https://lilianweng.github.io/feed.xml"
                 htmlUrl="https://lilianweng.github.io/"/>
      </outline>
    </outline>

    <!-- ============================================================ -->
    <!-- Tier 2：高价值源，每周看一次                                       -->
